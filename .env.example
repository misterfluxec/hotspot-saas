# Variables de entorno para HotSpot SaaS
# Copiar este archivo a .env y configurar los valores reales

# Base de datos PostgreSQL
DATABASE_URL="postgresql://hotspot_admin:HotSpot2024Ecuador@192.168.254.50:5433/hotspot_saas"

# Redis para caché y sesiones
REDIS_URL="redis://:Redis2024Safe@192.168.254.50:6379"

# Ollama IA local
OLLAMA_BASE_URL="http://192.168.254.50:11434"
OLLAMA_MODEL="phi3:latest"

# JWT para autenticación
JWT_SECRET="tu-jwt-secret-aqui-cambiar-en-produccion"
JWT_EXPIRES_IN="7d"

# URLs de las aplicaciones (CRÍTICO para Proxy Inverso)
NEXT_PUBLIC_DASHBOARD_URL="https://saas.labodegaec.com"
NEXT_PUBLIC_PORTAL_URL="https://portal.labodegaec.com"
NEXT_PUBLIC_API_URL="https://saas.labodegaec.com/api"

# Dominio base
DOMAIN_BASE="labodegaec.com"
NEXT_PUBLIC_DOMAIN_BASE="labodegaec.com"

# MercadoPago para pagos
MERCADOPAGO_ACCESS_TOKEN="tu-access-token-de-mercadopago"
MERCADOPAGO_WEBHOOK_SECRET="tu-webhook-secret"

# Configuración de correo
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="tu-email@dominio.com"
SMTP_PASS="tu-contraseña-de-app"

# Configuración de puertos (para desarrollo local)
DASHBOARD_PORT=3003
PORTAL_PORT=3000

# Configuración de desarrollo
NODE_ENV="development"

# Configuración de uploads
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE="5MB"

# Logs
LOG_LEVEL="info"
LOG_FILE="./logs/app.log"
