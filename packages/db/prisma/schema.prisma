generator client {
  provider      = "prisma-client-js"
  // ✅ CORREGIDO: Ruta relativa correcta para monorepo desde packages/db/prisma/
  // ../../ = root del proyecto (/app en Docker)
  output        = "../../../node_modules/.prisma/client"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id            String    @id @default(cuid())
  name          String
  slug          String    @unique
  businessType  String
  billingEmail  String
  status        String    @default("trial") // 'trial' | 'active' | 'suspended'
  trialEndsAt   DateTime?
  planId        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relaciones
  users         User[]
  branches      Branch[]
  portals       Portal[]
  visitors      Visitor[]
  campaigns     Campaign[]
  subscriptions Subscription[]

  @@map("tenants")
}

model User {
  id            String   @id @default(cuid())
  tenantId      String
  email         String
  passwordHash  String   @map("password_hash")  // ← CRÍTICO: Mapeo correcto
  role          String   @default("admin")      // 'admin' | 'superadmin'
  name          String?
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relaciones
  tenant        Tenant   @relation(fields: [tenantId], references: [id])

  // Índices únicos por tenant
  @@unique([tenantId, email])
  @@map("users")
}

model Plan {
  id            String   @id @default(cuid())  // ← Se sobrescribe en seed con IDs fijos
  name          String
  priceMonthly  Float
  maxPortals    Int
  maxBranches   Int
  maxVisitorsMo Int
  aiRequestsMo Int
  features      Json?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relaciones
  subscriptions Subscription[]

  @@map("plans")
}

model Branch {
  id           String   @id @default(cuid())
  tenantId     String
  name         String
  address      String?
  timezone     String?  @default("America/Guayaquil")
  routerType   String?  // 'mikrotik' | 'ubiquiti' | 'other'
  routerIp     String?
  routerUser   String?
  routerPassEnc String? // Encriptada
  portalId     String?
  isOnline     Boolean  @default(false)
  lastSeenAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relaciones
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  portal       Portal?  @relation(fields: [portalId], references: [id])
  visitors     Visitor[]

  @@map("branches")
}

model Portal {
  id            String   @id @default(cuid())
  tenantId      String
  name          String
  template      String   @default("aura")  // 'aura' | 'pulse' | 'vibe'
  subdomain     String?  @unique
  config        Json?
  sessionMinutes Int     @default(60)
  speedKbps     Int?
  quotaMb       Int?
  isPublished   Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relaciones
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  branches      Branch[]

  @@map("portals")
}

model Visitor {
  id          String   @id @default(cuid())
  tenantId    String
  branchId    String?
  name        String?
  email       String?
  phone       String?
  macAddress  String
  visitCount  Int      @default(1)
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  // Relaciones
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  branch      Branch?  @relation(fields: [branchId], references: [id])

  @@map("visitors")
}

model Campaign {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  type      String   // 'email' | 'sms' | 'push'
  assetUrl  String?
  clickUrl  String?
  weight    Int      @default(1)
  schedule  Json?
  branchIds String[] // IDs de sucursales objetivo
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  tenant     Tenant   @relation(fields: [tenantId], references: [id])

  @@map("campaigns")
}

model Subscription {
  id              String   @id @default(cuid())
  tenantId        String
  planId          String
  mpPreapprovalId String?  // MercadoPago
  status          String   @default("trial")  // 'trial' | 'active' | 'cancelled'
  currentPeriodEnd DateTime?
  amountUsd       Float
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relaciones
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  plan            Plan     @relation(fields: [planId], references: [id])

  @@map("subscriptions")
}
